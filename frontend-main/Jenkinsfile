pipeline {
    agent any

    environment {
        REGISTRY = 'registry.gitlab.com'
        IMAGE_NAME = 'registry.gitlab.com/stingray8210926/frontend'
        CREDENTIALS_ID = 'gitlab-pat'
        NEXT_PUBLIC_API_URL = 'https://api.metoru.com/api'
        NEXT_PUBLIC_APP_NAME = 'CSMJU'
        NEXT_PUBLIC_APP_DESCRIPTION = 'Computer Science, Science, Maejo University Web Application'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push Image') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: "${CREDENTIALS_ID}",
                        usernameVariable: 'GITLAB_USERNAME',
                        passwordVariable: 'GITLAB_PASSWORD'
                    )
                ]) {
                    sh '''
                        echo "$GITLAB_PASSWORD" | docker login "$REGISTRY" -u "$GITLAB_USERNAME" --password-stdin
                        
                        docker build \
                            --build-arg NEXT_PUBLIC_API_URL="$NEXT_PUBLIC_API_URL" \
                            --build-arg NEXT_PUBLIC_APP_NAME="$NEXT_PUBLIC_APP_NAME" \
                            --build-arg NEXT_PUBLIC_APP_DESCRIPTION="$NEXT_PUBLIC_APP_DESCRIPTION" \
                            -t "$IMAGE_NAME:$BUILD_ID" \
                            -t "$IMAGE_NAME:latest" \
                            .
                        
                        docker push "$IMAGE_NAME:$BUILD_ID"
                        docker push "$IMAGE_NAME:latest"
                        
                        docker logout "$REGISTRY"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Successfully built and pushed ${IMAGE_NAME}:${env.BUILD_ID}"
        }
        failure {
            echo "Pipeline failed. Check the logs for Docker or Credential issues."
        }
    }
}